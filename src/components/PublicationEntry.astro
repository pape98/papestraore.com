---
interface Props {
  title: string;
  authors: string;
  venue: string;
  year: number;
  doi?: string;
  badge?: string;
  stats?: string;
}

const { title, authors, venue, year, doi, badge, stats } = Astro.props;
---

<div class="py-5">
  <div class="flex items-start justify-between gap-4 mb-1">
    <span class="text-base font-medium text-neutral-900 leading-snug">{title}</span>
    {doi && (
      <a
        href={doi}
        target="_blank"
        rel="noopener noreferrer"
        class="text-base text-neutral-500 hover:text-neutral-700 transition-colors shrink-0 mt-0.5"
      >
        ↗
      </a>
    )}
  </div>
  <p class="text-base text-neutral-600 mb-1">{authors}</p>
  <div class="flex items-center gap-2">
    <span class="text-sm text-neutral-500">{venue} · {year}</span>
    {badge && (
      <span class="text-sm text-neutral-600 border border-neutral-300 rounded px-1.5 py-0.5">
        {badge}
      </span>
    )}
    {stats && (
      <span class="text-sm text-neutral-500">{stats}</span>
    )}
  </div>
</div>
