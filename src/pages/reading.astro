---
import BaseLayout from "../layouts/BaseLayout.astro";
import BookEntry from "../components/BookEntry.astro";
import { currentlyReading, nerdStuff, everythingElse } from "../data/books";
---

<BaseLayout title="Reading — Pape Sow Traore">
  <p class="text-base text-neutral-600 mb-10">Books I love, am reading, or keep meaning to finish. Mostly nerd stuff but I have range.</p>
  <section class="mb-10">
    <h2 class="text-sm uppercase tracking-widest text-neutral-600 mb-4">Currently Reading</h2>
    {currentlyReading.map((b) => <BookEntry {...b} />)}
  </section>

  <section class="mb-10">
    <h2 class="text-sm uppercase tracking-widest text-neutral-600 mb-4">Nerd Stuff 🤓</h2>
    {nerdStuff.map((b) => <BookEntry {...b} />)}
  </section>

  {everythingElse.length > 0 && (
    <section>
      <h2 class="text-sm uppercase tracking-widest text-neutral-600 mb-4">Everything Else</h2>
      {everythingElse.map((b) => <BookEntry {...b} />)}
    </section>
  )}
</BaseLayout>
